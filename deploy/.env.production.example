# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  TFC — Production Environment Variables                                     ║
# ║  Copy this file to .env and fill in REAL values before deploying.           ║
# ║  NEVER commit the actual .env file to Git!                                  ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

NODE_ENV=production
PORT=3001

# ── Frontend URL (used for CORS, redirects, email links) ──────────────────────
FRONTEND_URL=https://tfc-event.com

# ── Firebase Admin SDK ────────────────────────────────────────────────────────
# Get these from: Firebase Console → Project Settings → Service Accounts
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ── Firebase Client Config (for frontend — these are PUBLIC keys) ─────────────
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxx

# ── Stripe (Payment Processing) ──────────────────────────────────────────────
# Get these from: https://dashboard.stripe.com/apikeys
# ⚠️  Use LIVE keys for production, TEST keys for development
STRIPE_SECRET_KEY=sk_live_REPLACE_WITH_NEW_KEY
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_WEBHOOK_SECRET
STRIPE_MONTHLY_PRICE_ID=price_REPLACE_WITH_MONTHLY_PRICE_ID
STRIPE_YEARLY_PRICE_ID=price_REPLACE_WITH_YEARLY_PRICE_ID

# ── NOWPayments (Crypto Payments) ────────────────────────────────────────────
# Get these from: https://account.nowpayments.io/
NOWPAYMENTS_API_KEY=REPLACE_WITH_NOWPAYMENTS_API_KEY
NOWPAYMENTS_IPN_SECRET=REPLACE_WITH_IPN_SECRET
NOWPAYMENTS_IPN_URL=https://tfc-event.com/api/webhooks/nowpayments

# ── Resend (Email Service) ───────────────────────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_REPLACE_WITH_RESEND_KEY

# ── ImgBB (Image Hosting for Champion Photos) ────────────────────────────────
# Get from: https://api.imgbb.com/
IMGBB_API_KEY=REPLACE_WITH_IMGBB_KEY

# ── Admin Email ──────────────────────────────────────────────────────────────
ADMIN_EMAIL=benbrayekhamza1@gmail.com

# ── Payment Redirect URLs ───────────────────────────────────────────────────
SUCCESS_URL=https://tfc-event.com/payment/success
CANCEL_URL=https://tfc-event.com/subscription

# ── Backend URL (used by frontend via Vite) ──────────────────────────────────
VITE_BACKEND_URL=https://tfc-event.com
